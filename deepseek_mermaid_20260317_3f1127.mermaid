graph TD
    subgraph "Traditional Perimeter Security (Implicit Trust)"
        A[Internet] --> B[Perimeter Firewall]
        B --> C[Trust Boundary]
        C --> D[Internal Network]
        D --> E[Web Server<br/>Ports: 22,80,443,8080]
        D --> F[Database Server<br/>Ports: 22,3306]
        D --> G[Attacker]
        G -->|Lateral Movement| E
        G -->|Lateral Movement| F
    end

    subgraph "Zero Trust Architecture (NIST SP 800-207)"
        H[Internet] --> I{Identity-Based<br/>Access Control}
        I -->|GitHub SSO| J[Tailscale Mesh Network]
        
        subgraph "Trust Boundary"
            K[Web Service<br/>Port 8080 Only]
            L[Database Service<br/>Port 3306 Only]
            M[SSH Access<br/>Port 22 Only]
        end
        
        J -->|Identity: Senior Admin| K
        J -->|Identity: Senior Admin| L
        J -->|Identity: Junior Admin| M
        
        N[Attacker] -->|No Valid Identity| I
        N -.->|Blocked| K
        N -.->|Blocked| L
        N -.->|Blocked| M
    end

    style B fill:#f96,stroke:#333,stroke-width:2px
    style C fill:#ff9,stroke:#333,stroke-width:2px
    style I fill:#9f9,stroke:#333,stroke-width:2px
    style J fill:#6cf,stroke:#333,stroke-width:2px
    style N fill:#f99